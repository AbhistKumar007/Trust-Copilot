# Backend Environment Variables (backend/.env)
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Etherscan / Polygonscan equivalent (https://etherscan.io/myapikey)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Covalent API Key (https://www.covalenthq.com/platform/)
COVALENT_API_KEY=your_covalent_api_key_here

# OpenAI API Key (https://platform.openai.com/api-keys)
# Claude could be used too based on configuration
OPENAI_API_KEY=your_openai_api_key_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Smart Contract
TRUST_SCORE_CONTRACT_ADDRESS=your_deployed_contract_address_here
BLOCKCHAIN_RPC_URL=http://localhost:8545

# ---------------------------------------------------------
# Contracts Environment Variables (contracts/.env)
PRIVATE_KEY=your_wallet_private_key_here
POLYGON_MUMBAI_RPC=https://rpc-mumbai.maticvigil.com
POLYGON_RPC=https://polygon-rpc.com
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
REPORT_GAS=true

# ---------------------------------------------------------
# Frontend Environment Variables (frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:5000/api
